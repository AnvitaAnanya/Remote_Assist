rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users can read/write their own profile
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Calls collection — any signed-in user can create or read calls.
    // Only participants (elder or caregiver) can update/delete.
    match /calls/{callId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null && (
        request.auth.uid == resource.data.elderId ||
        request.auth.uid == resource.data.caregiverId ||
        // Allow caregiver to set their ID on first answer (caregiverId not yet set)
        resource.data.caregiverId == null
      );
      allow delete: if false;

      // ICE candidate subcollections
      match /offerCandidates/{candidateId} {
        allow read, write: if request.auth != null;
      }
      match /answerCandidates/{candidateId} {
        allow read, write: if request.auth != null;
      }
    }
  }
}
